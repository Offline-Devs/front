# Frontend environment template. Copy to .env.local for local development.
# Never commit real secrets. NEXT_PUBLIC_* values are exposed to browsers.

# App identity (public, build-time)
NEXT_PUBLIC_APP_NAME=آکادمی نوشیروانی
NEXT_PUBLIC_APP_SHORT_NAME=نوشیروانی
NEXT_PUBLIC_APP_DESCRIPTION=سامانه مدیریت آزمون و مشاوره تحصیلی آکادمی نوشیروانی
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_PATH=/api/v1
NEXT_PUBLIC_LOCALE=fa-IR
NEXT_PUBLIC_TIME_ZONE=Asia/Tehran

# Contact links (public, build-time)
NEXT_PUBLIC_SUPPORT_EMAIL=support@noshirvaniacademy.com
NEXT_PUBLIC_SUPPORT_PHONE=+981112345678
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TELEGRAM_URL=

# Query cache and UX (public, build-time)
NEXT_PUBLIC_QUERY_STALE_TIME_MS=60000
NEXT_PUBLIC_QUERY_GC_TIME_MS=600000
NEXT_PUBLIC_QUERY_RETRY_COUNT=1
NEXT_PUBLIC_QUERY_REFETCH_ON_WINDOW_FOCUS=false
NEXT_PUBLIC_OTP_RESEND_SECONDS=120
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20

# Upload limits; keep aligned with the backend
NEXT_PUBLIC_PROFILE_UPLOAD_MAX_MB=10
NEXT_PUBLIC_DOCUMENT_UPLOAD_MAX_MB=50
NEXT_PUBLIC_MULTIPLE_UPLOAD_MAX_FILES=10

# UI feature flags; these are not security controls
NEXT_PUBLIC_ENABLE_BLOG=true
NEXT_PUBLIC_ENABLE_CONTACT_PAGE=true

# CI performance budgets
PERF_MAX_INITIAL_JS_GZIP_KB=420
PERF_MAX_IMAGE_KB=250
PERF_MAX_TOTAL_FONT_KB=250

# Backend runtime (server-only)
API_BASE_URL=http://localhost:8080
API_TIMEOUT_MS=15000
LOG_LEVEL=info

# Docker-managed backend runtime and OTP provider
# Production requires BACKEND_ENVIRONMENT=production, OTP_PROVIDER=smsir, and EXPOSE_MOCK_OTP=false.
BACKEND_ENVIRONMENT=development
OTP_PROVIDER=mock
EXPOSE_MOCK_OTP=true
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Enforced BFF upload limits; keep aligned with public values and backend
PROFILE_UPLOAD_MAX_MB=10
DOCUMENT_UPLOAD_MAX_MB=50
MULTIPLE_UPLOAD_MAX_FILES=10

# BFF session cookie (server-only)
BFF_SESSION_COOKIE_NAME=noshirvani_session
BFF_SESSION_COOKIE_DOMAIN=
BFF_SESSION_COOKIE_SECURE=auto
BFF_SESSION_COOKIE_SAME_SITE=lax
BFF_SESSION_MAX_AGE_SECONDS=1296000
# Use a random value of at least 32 characters in production.
BFF_SESSION_SECRET=

# Next.js runtime
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
