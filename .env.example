# ==============================================================================
# Noshirvani Academy Frontend — Environment Variables
# ==============================================================================
# این فایل شامل مقدار نمونه است و secret واقعی نباید در Git ثبت شود.
# برای توسعه محلی آن را با نام .env.local کپی کنید.
# متغیرهای NEXT_PUBLIC_* داخل bundle مرورگر قرار می‌گیرند و محرمانه نیستند.
# متغیرهای public در Next.js هنگام build تثبیت می‌شوند؛ برای تغییرشان image را rebuild کنید.

# ------------------------------------------------------------------------------
# Application identity — عمومی
# ------------------------------------------------------------------------------
# نام کامل؛ در title تب، metadata و footer استفاده می‌شود.
NEXT_PUBLIC_APP_NAME=آکادمی نوشیروانی

# نام کوتاه برای موبایل، PWA و فضاهای محدود.
NEXT_PUBLIC_APP_SHORT_NAME=نوشیروانی

# توضیح پیش‌فرض SEO و metadata.
NEXT_PUBLIC_APP_DESCRIPTION=سامانه مدیریت آزمون و مشاوره تحصیلی آکادمی نوشیروانی

# نسخه نمایشی frontend؛ بهتر است CI آن را از tag یا commit SHA مقداردهی کند.
NEXT_PUBLIC_APP_VERSION=0.1.0

# محیط قابل مشاهده برنامه؛ برای badge، devtools و رفتارهای غیرحساس.
NEXT_PUBLIC_APP_ENV=development

# آدرس عمومی و canonical سایت؛ حتماً شامل protocol و بدون slash انتهایی باشد.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# مسیر same-origin درگاه API. با route موجود /api/v1 هماهنگ نگه داشته شود.
NEXT_PUBLIC_API_BASE_PATH=/api/v1

# locale نمایش اعداد/تاریخ و timezone رسمی برنامه.
NEXT_PUBLIC_LOCALE=fa-IR
NEXT_PUBLIC_TIME_ZONE=Asia/Tehran

# ------------------------------------------------------------------------------
# Contact and social links — عمومی
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPPORT_EMAIL=support@noshirvaniacademy.com
NEXT_PUBLIC_SUPPORT_PHONE=+981112345678
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TELEGRAM_URL=

# ------------------------------------------------------------------------------
# UX and cache tuning — عمومی
# ------------------------------------------------------------------------------
# زمان تازه‌بودن queryها و زمان نگهداری query غیرفعال در cache، میلی‌ثانیه.
NEXT_PUBLIC_QUERY_STALE_TIME_MS=60000
NEXT_PUBLIC_QUERY_GC_TIME_MS=600000
NEXT_PUBLIC_QUERY_RETRY_COUNT=1
NEXT_PUBLIC_QUERY_REFETCH_ON_WINDOW_FOCUS=false

# زمان فعال‌شدن ارسال مجدد OTP، ثانیه.
NEXT_PUBLIC_OTP_RESEND_SECONDS=120

# اندازه پیش‌فرض صفحه مدیریت دانش‌آموزان؛ backend حداکثر 100 را می‌پذیرد.
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20

# محدودیت‌های UI آپلود؛ باید با backend هماهنگ باشند.
NEXT_PUBLIC_PROFILE_UPLOAD_MAX_MB=10
NEXT_PUBLIC_DOCUMENT_UPLOAD_MAX_MB=50
NEXT_PUBLIC_MULTIPLE_UPLOAD_MAX_FILES=10

# ------------------------------------------------------------------------------
# Feature flags — عمومی
# ------------------------------------------------------------------------------
# فقط true یا false. این flagها مجوز امنیتی نیستند و صرفاً UI را کنترل می‌کنند.
NEXT_PUBLIC_ENABLE_BLOG=true
NEXT_PUBLIC_ENABLE_CONTACT_PAGE=true
NEXT_PUBLIC_ENABLE_QUERY_DEVTOOLS=true

# ------------------------------------------------------------------------------
# Backend and server runtime — محرمانه/داخلی
# ------------------------------------------------------------------------------
# آدرس واقعی backend برای Route Handler سرور Next؛ هرگز NEXT_PUBLIC نباشد.
# توسعه محلی: http://localhost:8080
# Docker محلی: http://host.docker.internal:8080
# Production: آدرس داخلی سرویس backend یا load balancer خصوصی.
API_BASE_URL=http://localhost:8080

# timeout ارتباط سرور Next با backend بر حسب میلی‌ثانیه؛ بازه معتبر 1..60000.
API_TIMEOUT_MS=15000

# محیط runtime سمت سرور و سطح log مجاز.
APP_ENV=development
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# BFF session cookie — سروری، برای فاز احراز هویت
# ------------------------------------------------------------------------------
# نام cookie نباید بین staging و production مشترک باشد.
BFF_SESSION_COOKIE_NAME=noshirvani_session

# خالی یعنی host-only cookie؛ در production فقط در صورت نیاز دامنه تنظیم شود.
BFF_SESSION_COOKIE_DOMAIN=

# auto در production Secure و در development غیر Secure است.
BFF_SESSION_COOKIE_SECURE=auto
BFF_SESSION_COOKIE_SAME_SITE=lax
BFF_SESSION_MAX_AGE_SECONDS=1296000

# secret حداقل 32 کاراکتری برای رمزنگاری/sign نشست؛ در secret manager نگهداری شود.
# نمونه تولید: openssl rand -base64 48
BFF_SESSION_SECRET=

# ------------------------------------------------------------------------------
# Next.js runtime
# ------------------------------------------------------------------------------
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
